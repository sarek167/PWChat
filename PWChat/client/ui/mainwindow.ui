  <property name="styleSheet">
   <string notr="true">QWidget[class=&quot;MainWidget&quot;]{
	background-color: #a8a8a8;
}

QWidget[class=&quot;MenuWidget&quot;]{
	background-color: #fff;
	border-radius: 10px;
}

QWidget[class=&quot;inputWidget&quot;] {
	background-color: #fff;
	border-radius: 10px;
}

QFrame[class=&quot;sideWidget&quot;]{
	background-color: #fff;
	border-radius: 10px;
	color: black;
}

QScrollArea#sideScroll {
	background-color: #fff;
	color: black;
}

QWidget#MessagesWidget {
	background-color:  #a8a8a8;
	border: 0;
}

QLineEdit {
	border-radius: 10px;
	border: 1px solid #212121;
	padding: 5px 15px;
}

QLineEdit#editMess {
  border: 0;
}

QPushButton {
	background-color: #212121;
	color: white;
	border-radius: 10px;
	padding: 5px 15px;
	border: 1px solid #212121;
}

QPushButton:hover {
	background-color: #fff;
	color: #212121
}

QPushButton#btnRecordAudio {
	qproperty-icon: url(&quot;:/mic-icon-white.svg&quot;);
	icon-size: 32px;
	height: 48px;
	width: 48px;
	background-color: #ab1a1a;
	border: 1px solid #ab1a1a;
	border-radius: 24px;
	padding: 0;
}


QPushButton#btnSend {
	qproperty-icon: url(&quot;:/send-icon-white.svg&quot;);
	icon-size: 24px;
	height: 48px;
	width: 48px;
	padding: 0;
	border-radius: 24px
}


QPushButton#btnSend:hover {
	qproperty-icon: url(&quot;:/send-icon-black.svg&quot;);

}

QPushButton#btnExit {
	qproperty-icon: url(&quot;:/close-icon-white.svg&quot;);
	icon-size: 24px;
	height: 48px;
	width: 48px;
	padding: 0;
	border-radius: 24px
}

QPushButton#btnExit:hover {
	qproperty-icon: url(&quot;:/close-icon-black.svg&quot;);
}

QPushButton.RoomCard, QPushButton.UserCard {
	min-height: 32px;
    background-color: white;
    color: black;
    border-radius: 10px;
    padding: 5px;
    border: none;
    text-align: left;
}

QPushButton.RoomCard[active=&quot;true&quot;] {
    background-color: #212121;
    color: white;
}

QPushButton.RoomCard[active=&quot;true&quot;] QLabel {
    color: white;
}

QPushButton.RoomCard[active=&quot;false&quot;] QLabel, QPushButton.UserCard[active=&quot;false&quot;] QLabel {
    color: black;
}</string>
